@{
    ViewData["Title"] = "Galería";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
}

<style>
    .galeria-container {
        max-width: 1400px;
        margin: 40px auto;
        padding: 20px;
    }

    .galeria-titulo {
        text-align: center;
        color: #facc15;
        margin-bottom: 40px;
        font-size: 3rem;
    }

    .galeria-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .imagen-card {
        background: #1e293b;
        border-radius: 10px;
        overflow: hidden;
        border: 2px solid #334155;
        transition: 0.3s;
    }

        .imagen-card:hover {
            transform: scale(1.03);
            border-color: #facc15;
        }

        .imagen-card img {
            width: 100%;
            height: 250px;
            object-fit: cover;
            display: block;
        }

    @@media(max-width: 992px) {
        .galeria-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(max-width: 768px) {
        .galeria-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="galeria-container">

    <h1 class="galeria-titulo">Galería Yampi BarberShop</h1>

    <div class="galeria-grid">

        @for (int i = 1; i <= 15; i++)
        {
            <div class="imagen-card">
                <img src="~/images/galeria/@(i).jpg"
                     alt="Trabajo @(i)">
            </div>
        }

    </div>

</div>