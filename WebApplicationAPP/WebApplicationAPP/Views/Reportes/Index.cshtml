<h2 class="mb-4">
    📊 Reportes
</h2>

<div class="row">

    <div class="col-md-4 mb-3">

        <div class="card p-3 text-center">

            <h5>
                📅 Citas del día
            </h5>

            <h2>
                @ViewBag.CitasHoy
            </h2>

        </div>

    </div>

    <div class="col-md-4 mb-3">

        <div class="card p-3 text-center">

            <h5>
                💰 Ingresos del día
            </h5>

            <h2 style="color:#198754;">
                ₡@ViewBag.IngresosHoy
            </h2>

            <small class="text-muted">
                Total de pagos registrados hoy.
            </small>

        </div>

    </div>

    <div class="col-md-4 mb-3">

        <div class="card p-3 text-center">

            <h5>
                ⭐ Clientes frecuentes
            </h5>

            <h2>
                @ViewBag.ClientesFrecuentes
            </h2>

        </div>

    </div>

</div>

<hr />

<div class="d-flex gap-2 mt-3">

    <a href="/Reportes/PorFecha"
           class="btn btn-primary">

        🔍 Reporte de Ingresos

    </a>

    <a href="/Reportes/ClientesFrecuentes"
           class="btn btn-success">

        ⭐ Clientes Frecuentes

    </a>

</div>