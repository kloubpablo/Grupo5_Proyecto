@using WebApplicationAPP.Models

<h2 class="mb-4">📅 Reporte por Fecha</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger text-center">
        @ViewBag.Error
    </div>
}

<form method="post" class="row g-2 align-items-end">

    <div class="col-md-8">

        <label class="form-label">
            Seleccione una fecha
        </label>

        <input class="form-control"
               type="date"
               name="fecha" />

    </div>

    <div class="col-md-4">

        <button class="btn btn-primary w-100"
                type="submit">

            🔍 Consultar

        </button>

    </div>

</form>

@if (ViewBag.Fecha != null)
{

    <div class="card p-4 mb-4 mt-4">

        <h3 class="text-center">
            📅 Consulta de ingresos del @ViewBag.Fecha
        </h3>

        <hr />

        <div class="row text-center">

            <div class="col-md-4">

                <h5>Citas registradas</h5>

                <h2>@ViewBag.Citas</h2>

            </div>

            <div class="col-md-4">

                <h5>Ingresos del día</h5>

                <h2 style="color:#198754;">
                    ₡@ViewBag.Total
                </h2>

            </div>

            <div class="col-md-4">

                <h5>Estado</h5>

                @if ((decimal)ViewBag.Total > 0)
                {
                    <span class="badge bg-success fs-6">
                        Con ingresos
                    </span>
                }
                else
                {
                    <span class="badge bg-danger fs-6">
                        Sin ingresos
                    </span>
                }

            </div>

        </div>

    </div>

    <div class="card p-4">

        <h4 class="mb-3">
            💳 Pagos registrados
        </h4>

        <table class="table table-bordered table-hover">

            <thead class="table-dark">

                <tr>

                    <th>Cliente</th>
                    <th>Monto</th>
                    <th>Método</th>

                </tr>

            </thead>

            <tbody>

                @{
                    var pagos = ViewBag.Pagos as List<Pago>;
                }

                @if (pagos == null || pagos.Count == 0)
                {
                    <tr>

                        <td colspan="3" class="text-center">

                            No existen pagos registrados para esta fecha.

                        </td>

                    </tr>
                }
                else
                {
                    @foreach (var pago in pagos)
                    {
                        <tr>

                            <td>

                                @pago.IdClienteNavigation?.Nombre

                            </td>

                            <td style="font-weight:bold; color:#198754;">

                                ₡@pago.Monto

                            </td>

                            <td>

                                @if (pago.Metodo == "Efectivo")
                                {
                                    <span class="badge bg-success">

                                        Efectivo

                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">

                                        Tarjeta

                                    </span>
                                }

                            </td>

                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

}