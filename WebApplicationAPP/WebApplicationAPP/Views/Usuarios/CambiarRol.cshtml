@using WebApplicationAPP.Models

<h2 class="mb-4">
    🔄 Cambiar Rol
</h2>

<div class="card p-4">

    <form method="post">

        <input type="hidden"
               name="idUsuario"
               value="@ViewBag.Usuario.IdUsuario" />

        <div class="mb-3">

            <label class="form-label">
                Usuario
            </label>

            <input class="form-control"
                   value="@ViewBag.Usuario.Nombre"
                   readonly />

        </div>

        <div class="mb-3">

            <label class="form-label">
                Rol Actual
            </label>

            <input class="form-control"
                   value="@ViewBag.Usuario.IdRolNavigation.Nombre"
                   readonly />

        </div>

        <div class="mb-3">

            <label class="form-label">
                Nuevo Rol
            </label>

            <select class="form-select"
                    name="idRol">

                @foreach (Role rol in ViewBag.Roles)
                {
                    <option value="@rol.IdRol">
                        @rol.Nombre
                    </option>
                }

            </select>

        </div>

        <div class="d-flex justify-content-between">

            <button type="submit"
                    class="btn btn-success">
                💾 Guardar Cambios
            </button>

            <a href="/Usuarios"
                   class="btn btn-secondary">
                Cancelar
            </a>

        </div>

    </form>

</div>