@model List<dynamic>

<h2 class="mb-4">💰 Pagos</h2>

<!-- 🔹 BOTONES -->
<div class="mb-3 d-flex gap-2">
    <a class="btn btn-primary" href="/Pagos/Registrar">
        ➕ Registrar Pago
    </a>

    <a class="btn btn-warning text-dark" href="/Pagos/Cierre">
        📊 Cierre de Caja
    </a>
</div>

<!-- 🔹 TABLA -->
<table class="table table-bordered text-center">
    <thead>
        <tr>
            <th>Cliente</th>
            <th>Monto</th>
            <th>Método</th>
            <th>Fecha</th>
        </tr>
    </thead>
    <tbody>

        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="4">No hay pagos registrados</td>
            </tr>
        }
        else
        {
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.cliente</td>

                    <!-- 💰 MONTO DESTACADO -->
                    <td style="font-weight:bold; color:#facc15;">
                        ₡@p.monto
                    </td>

                    <!-- 💳 MÉTODO -->
                    <td>
                        @if (p.metodo == "Efectivo")
                        {
                            <span class="badge bg-success">Efectivo</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Tarjeta</span>
                        }
                    </td>

                    <td>@p.fecha</td>
                </tr>
            }
        }

    </tbody>
</table>