@model WebApplicationAPP.Models.Cliente

<h2 class="mb-4">✏️ Editar Cliente</h2>

<div class="card p-4">

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger text-center">
            @ViewBag.Error
        </div>
    }

    <form method="post">

        <input type="hidden"
               name="id"
               value="@Model.IdCliente" />

        <div class="mb-3">

            <label class="form-label">
                Nombre
            </label>

            <input class="form-control"
                   type="text"
                   name="nombre"
                   value="@Model.Nombre" />

        </div>

        <div class="mb-3">

            <label class="form-label">
                Teléfono
            </label>

            <input class="form-control"
                   type="text"
                   name="telefono"
                   value="@Model.Telefono" />

        </div>

        <div class="d-flex justify-content-between mt-4">

            <button class="btn btn-primary"
                    type="submit">

                💾 Guardar Cambios

            </button>

            <a class="btn btn-secondary"
                   href="/Clientes">

                Cancelar

            </a>

        </div>

    </form>

</div>