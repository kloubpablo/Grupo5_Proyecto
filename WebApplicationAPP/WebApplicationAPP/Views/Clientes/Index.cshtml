@model List<WebApplicationAPP.Models.Cliente>

<h2 class="mb-4">👤 Clientes</h2>

<div class="card p-3 mb-3">

    <form method="get"
          class="row g-2 align-items-center">

        <div class="col-md-9">

            <input class="form-control"
                   type="text"
                   name="buscar"
                   placeholder="🔍 Buscar por nombre o teléfono..." />

        </div>

        <div class="col-md-3">

            <button class="btn btn-primary w-100"
                    type="submit">
                Buscar
            </button>

        </div>

    </form>

</div>

<div class="mb-3">

    <a class="btn btn-primary"
           href="/Clientes/Crear">

        ➕ Nuevo Cliente

    </a>

</div>

<table class="table table-bordered table-striped text-center align-middle">

    <thead class="table-dark">

        <tr>

            <th style="width:10%;">
                ID
            </th>

            <th style="width:30%;">
                Nombre
            </th>

            <th style="width:20%;">
                Teléfono
            </th>

            <th style="width:20%;">
                Fecha Registro
            </th>

            <th style="width:20%;">
                Acciones
            </th>

        </tr>

    </thead>

    <tbody>

        @if (Model == null || Model.Count == 0)
        {
            <tr>

                <td colspan="5">
                    No hay clientes registrados
                </td>

            </tr>
        }
        else
        {
            @foreach (var c in Model)
            {
                <tr>

                    <td>
                        @c.IdCliente
                    </td>

                    <td>
                        @c.Nombre
                    </td>

                    <td>
                        @c.Telefono
                    </td>

                    <td>
                        @(c.FechaRegistro.HasValue
                            ? c.FechaRegistro.Value.ToString("dd/MM/yyyy")
                            : "Sin fecha")
                    </td>

                    <td>

                        <a class="btn btn-sm btn-warning text-dark"
                               href="/Clientes/Editar/@c.IdCliente">

                            ✏️ Editar

                        </a>

                    </td>

                </tr>
            }
        }

    </tbody>

</table>