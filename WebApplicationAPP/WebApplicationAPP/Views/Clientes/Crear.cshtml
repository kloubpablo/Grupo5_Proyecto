<h2 class="mb-4">➕ Registrar Cliente</h2>

<div class="card p-4">

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger text-center">
            @ViewBag.Error
        </div>
    }

    <form method="post">

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input class="form-control" type="text" name="nombre" placeholder="Ingrese el nombre" />
        </div>

        <div class="mb-3">
            <label class="form-label">Teléfono</label>
            <input class="form-control" type="text" name="telefono" placeholder="Ingrese el teléfono" />
        </div>

        <div class="d-flex justify-content-between mt-4">
            <button class="btn btn-primary" type="submit">
                💾 Guardar
            </button>

            <a class="btn btn-secondary" href="/Clientes">
                Cancelar
            </a>
        </div>

    </form>

</div>