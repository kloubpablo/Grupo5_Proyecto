@{
    ViewData["Title"] = "Registro";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
}

<style>
    .registro-container {
        min-height: calc(100vh - 250px);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
    }

    .registro-box {
        width: 100%;
        max-width: 500px;
    }

    .registro-card {
        background-color: #1e293b;
        border-radius: 15px;
        padding: 35px;
        box-shadow: 0 0 25px rgba(0,0,0,0.3);
    }

        .registro-card h2 span {
            color: #facc15;
        }

        .registro-card p {
            color: #cbd5e1;
        }

        .registro-card label {
            color: white;
            margin-bottom: 5px;
            display: block;
        }

        .registro-card input {
            background-color: #020617 !important;
            color: white !important;
            border: 1px solid #334155 !important;
        }

            .registro-card input:focus {
                border-color: #facc15 !important;
                box-shadow: none !important;
            }

    .links {
        margin-top: 20px;
        text-align: center;
    }

        .links a {
            color: #facc15;
            text-decoration: none;
        }

            .links a:hover {
                text-decoration: underline;
            }
</style>

<div class="registro-container">

    <div class="registro-box">

        <div class="registro-card">

            <header class="text-center mb-4">
                <h2 class="major">
                    <span>💈 Registro de Cliente</span>
                </h2>

                <p>
                    Cree su cuenta para agendar citas
                </p>
            </header>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger text-center">
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Seguridad"
                  asp-action="Registrar"
                  method="post">

                <div class="mb-3">
                    <label>Nombre Completo</label>

                    <input class="form-control"
                           type="text"
                           name="nombre"
                           required />
                </div>

                <div class="mb-3">
                    <label>Nombre de Usuario</label>

                    <input class="form-control"
                           type="text"
                           name="username"
                           required />
                </div>

                <div class="mb-3">
                    <label>Correo Electrónico</label>

                    <input class="form-control"
                           type="email"
                           name="correo"
                           required />
                </div>

                <div class="mb-3">
                    <label>Contraseña</label>

                    <input class="form-control"
                           type="password"
                           name="password"
                           required />
                </div>

                <button type="submit"
                        class="button primary w-100">
                    📝 Crear Cuenta
                </button>

            </form>

            <div class="links">

                <a asp-controller="Seguridad"
                   asp-action="Index">
                    ← Volver al Login
                </a>

            </div>

        </div>

    </div>

</div>