@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
}

<style>
    .recuperar-container {
        min-height: calc(100vh - 250px);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
    }

    .recuperar-box {
        width: 100%;
        max-width: 500px;
    }

    .recuperar-card {
        background-color: #1e293b;
        border-radius: 15px;
        padding: 35px;
        box-shadow: 0 0 25px rgba(0,0,0,0.3);
    }

        .recuperar-card h2 {
            color: #facc15;
        }

        .recuperar-card p {
            color: #cbd5e1;
        }

        .recuperar-card label {
            color: white;
            margin-bottom: 5px;
            display: block;
        }

        .recuperar-card input {
            background-color: #020617 !important;
            color: white !important;
            border: 1px solid #334155 !important;
        }

            .recuperar-card input:focus {
                border-color: #facc15 !important;
                box-shadow: none !important;
            }

    .mensaje-exito {
        color: #22c55e;
        text-align: center;
        margin-top: 15px;
    }

    .mensaje-error {
        color: #ef4444;
        text-align: center;
        margin-top: 15px;
    }

    .links {
        margin-top: 20px;
        text-align: center;
    }

        .links a {
            color: #facc15;
            text-decoration: none;
        }

            .links a:hover {
                text-decoration: underline;
            }
</style>

<div class="recuperar-container">

    <div class="recuperar-box">

        <div class="recuperar-card">

            <header class="text-center mb-4">
                <h2 class="major">
                    🔑 Recuperar Contraseña
                </h2>

                <p>
                    Ingrese el correo asociado a su cuenta
                </p>
            </header>

            <form asp-controller="Seguridad"
                  asp-action="Recuperar"
                  method="post">

                <div class="mb-3">

                    <label>Correo Electrónico</label>

                    <input class="form-control"
                           type="email"
                           name="correo"
                           placeholder="correo@ejemplo.com"
                           required />

                </div>

                <button type="submit"
                        class="button primary w-100">
                    📧 Recuperar
                </button>

            </form>

            @if (ViewBag.Mensaje != null)
            {
                <p class="mensaje-exito">
                    @ViewBag.Mensaje
                </p>
            }

            @if (ViewBag.Error != null)
            {
                <p class="mensaje-error">
                    @ViewBag.Error
                </p>
            }

            <div class="links">

                <a asp-controller="Seguridad"
                   asp-action="Index">
                    ← Volver al Login
                </a>

            </div>

        </div>

    </div>

</div>