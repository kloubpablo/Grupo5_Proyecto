@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Recuperar Contraseña</title>

    <link rel="stylesheet" href="~/assets/css/main.css" />

    <style>
            body {
                background-color: #0f172a;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                color: white;
            }

            .recuperar-box {
                width: 500px;
            }

            input {
                background-color: #020617 !important;
                color: white !important;
                border: 1px solid #334155 !important;
            }

            .links {
                margin-top: 15px;
                text-align: center;
            }

            .mensaje-exito {
                color: #22c55e;
                text-align: center;
                margin-top: 15px;
            }

            .mensaje-error {
                color: #ef4444;
                text-align: center;
                margin-top: 15px;
            }
    </style>
</head>

<body>

    <div class="recuperar-box">

        <section class="box">

            <header class="text-center">
                <h2 class="major">
                    🔑 Recuperar Contraseña
                </h2>

                <p style="color:#cbd5f5;">
                    Ingrese el correo asociado a su cuenta
                </p>
            </header>

            <form asp-controller="Seguridad"
                  asp-action="Recuperar"
                  method="post">

                <div class="mb-3">

                    <label>Correo Electrónico</label>

                    <input class="form-control"
                           type="email"
                           name="correo"
                           placeholder="correo@ejemplo.com"
                           required />

                </div>

                <br />

                <button type="submit"
                        class="button primary w-100">
                    📧 Recuperar
                </button>

            </form>

            @if (ViewBag.Mensaje != null)
            {
                <p class="mensaje-exito">
                    @ViewBag.Mensaje
                </p>
            }

            @if (ViewBag.Error != null)
            {
                <p class="mensaje-error">
                    @ViewBag.Error
                </p>
            }

            <div class="links">

                <a asp-controller="Seguridad"
                       asp-action="Index">
                    ← Volver al Login
                </a>

            </div>

        </section>

    </div>

</body>
</html>