@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
}

<style>
    .login-container {
        min-height: calc(100vh - 250px);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
    }

    .login-box {
        width: 100%;
        max-width: 450px;
    }

    .login-card {
        background-color: #1e293b;
        border-radius: 15px;
        padding: 35px;
        box-shadow: 0 0 25px rgba(0,0,0,0.3);
    }

        .login-card h2 span {
            color: #facc15;
        }

        .login-card p {
            color: #cbd5e1;
        }

        .login-card label {
            color: white;
            margin-bottom: 5px;
            display: block;
        }

        .login-card input {
            background-color: #020617 !important;
            color: white !important;
            border: 1px solid #334155 !important;
        }

            .login-card input:focus {
                border-color: #facc15 !important;
                box-shadow: none !important;
            }

    .links {
        margin-top: 20px;
        text-align: center;
    }

        .links a {
            display: block;
            margin-top: 10px;
            color: #facc15;
            text-decoration: none;
        }

            .links a:hover {
                text-decoration: underline;
            }
</style>

<div class="login-container">

    <div class="login-box">

        <div class="login-card">

            <header class="text-center mb-4">
                <h2 class="major">
                    <span>💈 YAMPI BARBERSHOP</span>
                </h2>

                <p>
                    Inicio de sesión
                </p>
            </header>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger text-center">
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Seguridad"
                  asp-action="Index"
                  method="post">

                <div class="mb-3">
                    <label>Usuario</label>

                    <input class="form-control"
                           type="text"
                           name="usuario"
                           required />
                </div>

                <div class="mb-3">
                    <label>Contraseña</label>

                    <input class="form-control"
                           type="password"
                           name="password"
                           required />
                </div>

                <button type="submit"
                        class="button primary w-100">
                    🔐 Ingresar
                </button>

            </form>

            <div class="links">

                <a asp-controller="Seguridad"
                   asp-action="Recuperar">
                    ¿Olvidaste tu contraseña?
                </a>

                <a asp-controller="Seguridad"
                   asp-action="Registrar">
                    Registrarse
                </a>

            </div>

        </div>

    </div>

</div>