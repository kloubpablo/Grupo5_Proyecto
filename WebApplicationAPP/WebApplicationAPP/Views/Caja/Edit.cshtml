@model WebApplicationAPP.Models.Cajas

@{
    ViewBag.Title = "Editar Caja";
}

<h2>Editar Caja</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label class="form-label">ID</label>
        <input asp-for="Id"
               class="form-control"
               readonly />
    </div>

    <input type="hidden" asp-for="Id" />


    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre"
               class="form-control"
               placeholder="Nombre de la caja" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>


    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label"></label>
        <input asp-for="Descripcion"
               class="form-control"
               placeholder="Descripción de la caja" />
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>


    <div class="mb-3">
        <label asp-for="TelefonoSINPE" class="form-label"></label>
        <input asp-for="TelefonoSINPE"
               class="form-control"
               placeholder="88888888" />
        <span asp-validation-for="TelefonoSINPE" class="text-danger"></span>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="Estado" class="form-check-input" />
        <label asp-for="Estado" class="form-check-label">
            Caja activa
        </label>
    </div>

    <div class="mb-3">
        <a asp-action="Index" class="btn btn-danger">
            Cancelar
        </a>

        <button type="submit" class="btn btn-primary">
            Guardar
        </button>
    </div>
</form>