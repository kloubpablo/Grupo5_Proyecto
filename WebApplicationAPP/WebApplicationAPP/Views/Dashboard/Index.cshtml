@model List<WebApplicationAPP.Models.Usuario>

<h2 class="mb-4">📊 Dashboard</h2>

<!-- 🔹 RESUMEN -->
<div class="row text-center">

    <div class="col-md-4 mb-3">
        <div class="card p-3">
            <h5>📅 Citas del día</h5>
            <h2>@ViewBag.CitasHoy</h2>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card p-3">
            <h5>💰 Ingresos</h5>
            <h2>₡@ViewBag.IngresosHoy</h2>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card p-3">
            <h5>👤 Clientes atendidos</h5>
            <h2>@ViewBag.ClientesAtendidos</h2>
        </div>
    </div>

</div>

<hr />

<!-- 🔹 BARBEROS -->
<h3 class="mb-3">💈 Barberos</h3>

<table class="table table-bordered text-center">

    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Usuario</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.Nombre</td>
                <td>@b.Username</td>
            </tr>
        }
    </tbody>

</table>