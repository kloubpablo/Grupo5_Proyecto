
@using WebApplicationAPP.Models
@inject YampiBarbershopContext Db
@using Microsoft.EntityFrameworkCore
@inject WebApplicationAPP.Models.YampiBarbershopContext _context

@{
    var rol = Context.Session.GetString("Rol");
    var esAdmin = rol == "Administrador";

    var permisos = new List<string>();

    if (!esAdmin && !string.IsNullOrEmpty(rol))
    {
        permisos = _context.Roles
            .Include(r => r.IdPrivilegios)
            .Where(r => r.Nombre == rol)
            .SelectMany(r => r.IdPrivilegios.Select(p => p.Nombre))
            .ToList();
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Yampi Barbershop</title>



    <style>
        body {
            background-color: #0f172a !important;
            color: white;
        }

        #header {
            background: #020617 !important;
            border-bottom: 3px solid #facc15;
            text-align: center;
            padding: 15px 0;
        }

        #header h1 a {
            color: #facc15 !important;
            font-weight: bold;
            font-size: 24px;
            text-decoration: none;
        }

        #nav {
            background-color: #020617 !important;
            text-align: center;
            padding: 10px 0;
        }

        #nav ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        #nav ul li {
            display: inline-block;
            margin: 0 10px;
        }

        #nav ul li a {
            color: #facc15 !important;
            font-weight: 500;
            text-decoration: none;
            padding: 8px 12px;
            transition: 0.3s;
        }

        #nav ul li a:hover {
            background-color: #facc15;
            color: black !important;
            border-radius: 5px;
        }

        #main .container {
            background-color: #1e293b;
            padding: 25px;
            border-radius: 15px;
            margin-top: 20px;
        }
    </style>
</head>

<body>

<header id="header">
    <h1>
        <a asp-controller="Dashboard" asp-action="Index">
            💈 Yampi Barbershop
        </a>
    </h1>
</header>

@{
    var rol = Context.Session.GetString("Rol");
    var esAdmin = rol == "Administrador";
}

<nav id="nav">
    <ul>

        @if (!string.IsNullOrEmpty(rol))
        {
            if (esAdmin || WebApplicationAPP.Helpers.PermisosHelper.TienePermiso(Db, rol, "Dashboard/Index"))
            {
                <li><a asp-controller="Dashboard" asp-action="Index">📊 Dashboard</a></li>
            }

            if (esAdmin || WebApplicationAPP.Helpers.PermisosHelper.TienePermiso(Db, rol, "Clientes/Index"))
            {
                <li><a asp-controller="Clientes" asp-action="Index">👤 Clientes</a></li>
            }

            if (esAdmin || WebApplicationAPP.Helpers.PermisosHelper.TienePermiso(Db, rol, "Citas/Index"))
            {
                <li><a asp-controller="Citas" asp-action="Index">📅 Citas</a></li>
            }

            if (esAdmin || WebApplicationAPP.Helpers.PermisosHelper.TienePermiso(Db, rol, "Atencion/Index"))
            {
                <li><a asp-controller="Atencion" asp-action="Index">💈 Atención</a></li>
            }

            if (esAdmin || WebApplicationAPP.Helpers.PermisosHelper.TienePermiso(Db, rol, "Pagos/Index"))
            {
                <li><a asp-controller="Pagos" asp-action="Index">💰 Pagos</a></li>
            }

            if (esAdmin || WebApplicationAPP.Helpers.PermisosHelper.TienePermiso(Db, rol, "Reportes/Index"))
            {
                <li><a asp-controller="Reportes" asp-action="Index">📊 Reportes</a></li>
            }

            if (esAdmin || WebApplicationAPP.Helpers.PermisosHelper.TienePermiso(Db, rol, "Roles/Index"))
            {
                <li><a asp-controller="Roles" asp-action="Index">🛡️ Roles</a></li>
            }

            if (esAdmin || WebApplicationAPP.Helpers.PermisosHelper.TienePermiso(Db, rol, "Usuarios/Index"))
            {
                <li><a asp-controller="Usuarios" asp-action="Index">👤 Usuarios</a></li>
            }

            @if (rol == "Cliente")
            {
                <li>
                    <a asp-controller="Citas" asp-action="MisCitas">
                        📅 Mis Citas
                    </a>
                </li>

                <li>
                    <a asp-controller="Citas" asp-action="Crear">
                        ➕ Agendar Cita
                    </a>
                </li>
            }

            <li>
                <a asp-controller="Seguridad" asp-action="Logout">
                    🚪 Salir
                </a>
            </li>

            <li>
                <a asp-controller="Usuarios" asp-action="Perfil">
                    👤
                </a>
            </li>
        }

    </ul>
</nav>

<section id="main">
    <div class="container">
        @RenderBody()
    </div>
</section>

</body>
</html>