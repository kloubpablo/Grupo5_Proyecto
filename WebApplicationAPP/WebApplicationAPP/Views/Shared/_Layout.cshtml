
@using WebApplicationAPP.Models
@inject YampiBarbershopContext Db
@using Microsoft.EntityFrameworkCore
@inject WebApplicationAPP.Models.YampiBarbershopContext _context

@{
    var rol = Context.Session.GetString("Rol");
    var esAdmin = rol == "Administrador";

    var permisos = new List<string>();

    if (!esAdmin && !string.IsNullOrEmpty(rol))
    {
        permisos = _context.Roles
            .Include(r => r.IdPrivilegios)
            .Where(r => r.Nombre == rol)
            .SelectMany(r => r.IdPrivilegios.Select(p => p.Nombre))
            .ToList();
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Yampi Barbershop</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/assets/css/main.css" />

    <!-- 🔥 ESTILO BARBERÍA -->
    <style>

            body {
                background-color: #0f172a !important;
                color: white;
            }

            /* HEADER */
            #header {
                background: #020617 !important;
                border-bottom: 3px solid #facc15;
                text-align: center;
                padding: 15px 0;
            }

                #header h1 a {
                    color: #facc15 !important;
                    font-weight: bold;
                    font-size: 24px;
                    text-decoration: none;
                }

            /* NAVBAR */
            #nav {
                background-color: #020617 !important;
                text-align: center;
                padding: 10px 0;
            }

                #nav ul {
                    list-style: none;
                    padding: 0;
                    margin: 0;
                }

                    #nav ul li {
                        display: inline-block;
                        margin: 0 10px;
                    }

                        #nav ul li a {
                            color: #facc15 !important;
                            font-weight: 500;
                            text-decoration: none;
                            padding: 8px 12px;
                            transition: 0.3s;
                        }

                            #nav ul li a:hover {
                                background-color: #facc15;
                                color: black !important;
                                border-radius: 5px;
                            }

            /* CONTENIDO */
            #main .container {
                background-color: #1e293b;
                padding: 25px;
                border-radius: 15px;
                margin-top: 20px;
            }

    </style>
</head>

<body>

    <!-- HEADER -->
    <header id="header">
        <h1>
            <a asp-controller="Dashboard" asp-action="Index">
                💈 Yampi Barbershop
            </a>
        </h1>
    </header>

    <!-- NAVBAR -->
    <nav id="nav">
        <ul>

            <!-- DASHBOARD -->
            @if (Context.Session.GetString("Rol") != "Cliente")
            {
                <li>
                    <a asp-controller="Dashboard"
                       asp-action="Index">
                        📊 Dashboard
                    </a>
                </li>
            }

            <!-- 🔥 ADMINISTRADOR -->
            @if (Context.Session.GetString("Rol") == "Administrador")
            {
                <li>
                    <a asp-controller="Clientes"
                       asp-action="Index">
                        👤 Clientes
                    </a>
                </li>

                <li>
                    <a asp-controller="Citas"
                       asp-action="Index">
                        📅 Citas
                    </a>
                </li>

                <li>
                    <a asp-controller="Atencion"
                       asp-action="Index">
                        💈 Atención
                    </a>
                </li>

                <li>
                    <a asp-controller="Pagos"
                       asp-action="Index">
                        💰 Pagos
                    </a>
                </li>

                <li>
                    <a asp-controller="Reportes"
                       asp-action="Index">
                        📊 Reportes
                    </a>
                </li>

                <li>
                    <a asp-controller="Roles"
                       asp-action="Index">
                        🛡️ Roles
                    </a>
                </li>

                <li>
                    <a asp-controller="Usuarios"
                       asp-action="Index">
                        👤 Usuarios
                    </a>
                </li>
                <li>
                    <a asp-controller="YampiBarberShop"
                       asp-action="ControlGaleria">
                        Control de galeria
                    </a>
                </li>
            }

            <!-- 🔥 BARBERO -->
            @if (Context.Session.GetString("Rol") == "Barbero")
            {
                <li>
                    <a asp-controller="Citas"
                       asp-action="Index">
                        📅 Citas
                    </a>
                </li>

                <li>
                    <a asp-controller="Atencion"
                       asp-action="Index">
                        💈 Atención
                    </a>
                </li>
            }

            <!-- 🔥 RECEPCIONISTA -->
            @if (Context.Session.GetString("Rol") == "Recepcionista")
            {
                <li>
                    <a asp-controller="Clientes"
                       asp-action="Index">
                        👤 Clientes
                    </a>
                </li>

                <li>
                    <a asp-controller="Pagos"
                       asp-action="Index">
                        💰 Pagos
                    </a>
                </li>
            }

            @if (Context.Session.GetString("Rol") == "Cliente")
            {
                <li>
                    <a asp-controller="Citas"
                       asp-action="MisCitas">
                        📅 Mis Citas
                    </a>
                </li>

                <li>
                    <a asp-controller="Citas"
                       asp-action="Crear">
                        ➕ Agendar Cita
                    </a>
                </li>
            }

            <!-- CERRAR SESIÓN -->
            <li>
                <a asp-controller="Seguridad"
                   asp-action="Logout">
                    🚪 Salir
                </a>
            </li>

        </ul>
    </nav>

    <!-- CONTENIDO -->
    <section id="main">
        <div class="container">

            @RenderBody()

        </div>
    </section>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>