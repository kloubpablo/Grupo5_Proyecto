@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h2 class="mb-4 text-center">❌ Ocurrió un error</h2>

<div class="card p-4 text-center">

    <h4>Algo salió mal</h4>

    <p style="color:#cbd5f5;">
        Lo sentimos, ocurrió un problema al procesar la solicitud.
    </p>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>ID de solicitud:</strong>
            <code>@Model.RequestId</code>
        </p>
    }

    <hr />

    <p style="color:#94a3b8;">
        Puedes intentar nuevamente o volver al inicio.
    </p>

    <div class="mt-3">
        <a class="btn btn-primary" href="/">
            🏠 Ir al inicio
        </a>
    </div>

</div>