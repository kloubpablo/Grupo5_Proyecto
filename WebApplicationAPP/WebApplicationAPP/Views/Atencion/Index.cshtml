@model List<WebApplicationAPP.Models.Atencion>

@{
    ViewData["Title"] = "Registro de Atención";
}

<h2 class="mb-4">🪑 Registro de Atención</h2>

<form method="post"
      action="/Atencion/Agregar"
      class="row g-2 mb-4">

    <div class="col-md-8">
        <input class="form-control"
               type="text"
               name="nombre"
               placeholder="Nombre del cliente" />
    </div>

    <div class="col-md-4">
        <button class="btn btn-primary w-100">
            Agregar a lista
        </button>
    </div>

</form>

<table class="table table-bordered table-hover">

    <thead class="table-dark">
        <tr>
            <th>Cliente</th>
            <th>Cita</th>
            <th>Estado</th>
            <th>Hora Inicio</th>
            <th>Hora Fin</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>

        @if (Model == null || Model.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center">
                    No hay clientes en espera.
                </td>
            </tr>
        }
        else
        {
            @foreach (var c in Model)
            {
                <tr>

                    <td>
                        @c.IdClienteNavigation.Nombre
                    </td>

                    <td>

                        @if (c.IdCita != null)
                        {
                            <span class="badge bg-info">
                                Cita #@c.IdCita
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">
                                Sin cita
                            </span>
                        }

                    </td>

                    <td>

                        @if (c.Estado == "En espera")
                        {
                            <span class="badge bg-warning text-dark">
                                En espera
                            </span>
                        }
                        else if (c.Estado == "En servicio")
                        {
                            <span class="badge bg-success">
                                Atendiendo
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                Finalizado
                            </span>
                        }

                    </td>

                    <td>
                        @(c.HoraInicio?.ToString() ?? "--")
                    </td>

                    <td>
                        @(c.HoraFin?.ToString() ?? "--")
                    </td>

                    <td>

                        @if (c.Estado == "En espera")
                        {
                            <a class="btn btn-sm btn-primary"
                                   href="/Atencion/Iniciar/@c.IdAtencion">
                                ▶️ Iniciar
                            </a>
                        }
                        else if (c.Estado == "En servicio")
                        {
                            <a class="btn btn-sm btn-danger"
                                   href="/Atencion/Finalizar/@c.IdAtencion">
                                ⏹️ Finalizar
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">
                                Completado
                            </span>
                        }

                    </td>

                </tr>
            }
        }

    </tbody>

</table>

<div class="row mt-4">

    <div class="col-md-6">

        <div class="card p-3 text-center">

            <h5>
                ⏱ Tiempo estimado
            </h5>

            <h3>
                @((Model?.Count(c => c.Estado != "Finalizado") ?? 0) * 10) minutos
            </h3>

        </div>

    </div>

    <div class="col-md-6">

        <div class="card p-3 text-center">

            <h5>
                👥 Clientes en atención
            </h5>

            <h3>
                @(Model?.Count(c => c.Estado != "Finalizado") ?? 0)
            </h3>

        </div>

    </div>

</div>