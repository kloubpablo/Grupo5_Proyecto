@model List<WebApplicationAPP.Models.Role>

<h2 class="mb-4">🛡️ Gestión de Roles</h2>

<!-- BOTÓN -->
<div class="mb-3">

    <a class="btn btn-primary"
           href="/Roles/Crear">
        ➕ Nuevo Rol
    </a>

</div>

<!-- TABLA -->
<table class="table table-bordered table-striped text-center align-middle">

    <thead class="table-dark">

        <tr>
            <th style="width:40%;">
                Nombre
            </th>

            <th style="width:25%;">
                Estado
            </th>

            <th style="width:35%;">
                Acciones
            </th>
        </tr>

    </thead>

    <tbody>

        @if (Model == null || Model.Count == 0)
        {
            <tr>
                <td colspan="3">
                    No hay roles registrados
                </td>
            </tr>
        }
        else
        {
            @foreach (var r in Model)
            {
                <tr>

                    <!-- NOMBRE -->
                    <td>
                        @r.Nombre
                    </td>

                    <!-- ESTADO -->
                    <td>

                        @if (r.Estado)
                        {
                            <span class="badge bg-success">
                                Activo
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Inactivo
                            </span>
                        }

                    </td>

                    <!-- ACCIONES -->
                    <td>

                        <div class="d-flex justify-content-center gap-2">

                            <a class="btn btn-warning btn-sm text-dark"
                                   href="/Roles/Toggle/@r.IdRol">
                                🔄 Estado
                            </a>

                            <a class="btn btn-danger btn-sm"
                                   href="/Roles/Eliminar/@r.IdRol">
                                🗑 Eliminar
                            </a>

                        </div>

                    </td>

                </tr>
            }
        }

    </tbody>

</table>