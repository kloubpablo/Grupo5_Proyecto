@model IEnumerable<WebApplicationAPP.Models.Cita>

@{
    ViewData["Title"] = "Historial de Citas";
}

<h2 class="mb-4">
    📖 Historial de Citas
</h2>

<table class="table table-bordered table-striped">

    <thead class="table-dark">
        <tr>
            <th>Fecha</th>
            <th>Hora</th>
            <th>Barbero</th>
            <th>Estado</th>
        </tr>
    </thead>

    <tbody>

        @if (Model == null || !Model.Any())
        {
            <tr>
                <td colspan="4" class="text-center">
                    No existe historial de citas.
                </td>
            </tr>
        }
        else
        {
            @foreach (var cita in Model)
            {
                <tr>

                    <td>@cita.Fecha</td>

                    <td>@cita.Hora</td>

                    <td>@cita.Barbero</td>

                    <td>

                        @if (cita.Estado == "Activa")
                        {
                            <span class="badge bg-success">
                                Activa
                            </span>
                        }
                        else if (cita.Estado == "Cancelada")
                        {
                            <span class="badge bg-danger">
                                Cancelada
                            </span>
                        }
                        else if (cita.Estado == "Finalizada")
                        {
                            <span class="badge bg-primary">
                                Finalizada
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                @cita.Estado
                            </span>
                        }

                    </td>

                </tr>
            }
        }

    </tbody>

</table>

<a asp-action="MisCitas" class="btn btn-secondary">
    ← Volver
</a>