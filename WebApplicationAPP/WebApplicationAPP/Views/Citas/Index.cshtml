@model List<WebApplicationAPP.Models.Cita>

<h2 class="mb-4">📅 Citas</h2>

<div class="mb-3 d-flex gap-2">

    <a class="btn btn-success"
           href="/Citas/Crear">
        ➕ Nueva Cita
    </a>

    <a class="btn btn-primary"
           href="/Citas/Historial">
        📖 Historial de Citas
    </a>

</div>

<table class="table table-bordered table-hover">

    <thead class="table-dark">
        <tr>
            <th>Cliente</th>
            <th>Fecha</th>
            <th>Hora</th>
            <th>Barbero</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>

        @if (Model == null || Model.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center">
                    No hay citas registradas.
                </td>
            </tr>
        }
        else
        {
            @foreach (var c in Model)
            {
                <tr>

                    <td>@c.IdClienteNavigation.Nombre</td>

                    <td>@c.Fecha</td>

                    <td>@c.Hora</td>

                    <td>@c.Barbero</td>

                    <td>

                        @if (c.Estado == "Activa")
                        {
                            <span class="badge bg-success">
                                Activa
                            </span>
                        }
                        else if (c.Estado == "Cancelada")
                        {
                            <span class="badge bg-danger">
                                Cancelada
                            </span>
                        }
                        else if (c.Estado == "Finalizada")
                        {
                            <span class="badge bg-primary">
                                Finalizada
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                @c.Estado
                            </span>
                        }

                    </td>

                    <td>

                        @if (c.Estado == "Activa")
                        {
                            <a class="btn btn-sm btn-warning text-dark"
                                   href="/Citas/Editar/@c.IdCita">
                                ✏️ Editar
                            </a>

                            <a class="btn btn-sm btn-danger"
                                   href="/Citas/Cancelar/@c.IdCita">
                                ❌ Cancelar
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">
                                Sin acciones
                            </span>
                        }

                    </td>

                </tr>
            }
        }

    </tbody>

</table>