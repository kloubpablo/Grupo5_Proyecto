@model List<WebApplicationAPP.Models.Usuario>

<h3>💈 Estado de Barberos</h3>

<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Usuario</th>
            <th>Estado</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.Nombre</td>
                <td>@b.Username</td>

                <td>
                    @if (b.Estado)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (ViewBag.CitasProgramadas != null &&
((List<WebApplicationAPP.Models.Cita>)ViewBag.CitasProgramadas).Count > 0)
{
    <h3>📅 Citas Programadas de Hoy</h3>

    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID Cita</th>
                <th>ID Cliente</th>
                <th>Hora</th>
                <th>Barbero</th>
                <th>Estado</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var cita in (List<WebApplicationAPP.Models.Cita>)ViewBag.CitasProgramadas)
            {
                <tr>
                    <td>@cita.IdCita</td>
                    <td>@cita.IdCliente</td>
                    <td>@cita.Hora</td>
                    <td>@cita.Barbero</td>
                    <td>@cita.Estado</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No hay citas programadas para hoy.</p>
}