@model List<WebApplicationAPP.Models.Cita>

@{
    ViewData["Title"] = "Horarios Disponibles";
}

<h2 class="mb-4">
    🕒 Horarios Disponibles
</h2>

<div class="card p-4 mb-4">

    <form method="post">

        <div class="row">

            <div class="col-md-9">

                <label class="form-label">
                    Seleccione una fecha
                </label>

                <input class="form-control"
                       type="date"
                       name="fecha"
                       required />

            </div>

            <div class="col-md-3 d-flex align-items-end">

                <button class="btn btn-primary w-100"
                        type="submit">

                    Buscar

                </button>

            </div>

        </div>

    </form>

</div>

@if (ViewBag.Fecha != null)
{

    <div class="card p-4">

        <h4 class="mb-3">

            Horarios ocupados para
            @ViewBag.Fecha

        </h4>

        @if (Model == null || !Model.Any())
        {

            <div class="alert alert-success">

                No existen citas registradas para esta fecha.

                Todos los horarios están disponibles.

            </div>

        }
        else
        {

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>

                        <th>Hora</th>

                        <th>Barbero</th>

                        <th>Estado</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {

                        <tr>

                            <td>
                                @item.Hora
                            </td>

                            <td>
                                @item.Barbero
                            </td>

                            <td>
                                @item.Estado
                            </td>

                        </tr>

                    }

                </tbody>

            </table>

            <div class="alert alert-info mt-3">

                Los horarios que no aparecen en la lista se encuentran disponibles para nuevas citas.

            </div>

        }

    </div>

}