@model IEnumerable<WebApplicationAPP.Models.Cita>

@{
    ViewData["Title"] = "Mis Citas";
}

<h2 class="mb-4">📅 Mis Citas</h2>

<div class="mb-3">

    <a href="/Citas/Crear" class="btn btn-success">
        ➕ Nueva Cita
    </a>

    <a href="/Citas/Historial" class="btn btn-primary">
        📖 Historial de Citas
    </a>

</div>

<table class="table table-dark table-hover">

    <thead>
        <tr>
            <th>Fecha</th>
            <th>Hora</th>
            <th>Barbero</th>
            <th>Estado</th>
            <th>Acción</th>
        </tr>
    </thead>

    <tbody>

        @if (Model == null || !Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center">
                    No tienes citas registradas.
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Fecha</td>

                    <td>@item.Hora</td>

                    <td>@item.Barbero</td>

                    <td>

                        @if (item.Estado == "Activa")
                        {
                            <span class="badge bg-success">Activa</span>
                        }
                        else if (item.Estado == "Cancelada")
                        {
                            <span class="badge bg-danger">Cancelada</span>
                        }
                        else if (item.Estado == "Finalizada")
                        {
                            <span class="badge bg-primary">Finalizada</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@item.Estado</span>
                        }

                    </td>

                    <td>

                        @if (item.Estado == "Activa")
                        {
                            <a href="/Citas/Cancelar/@item.IdCita"
                                   class="btn btn-danger btn-sm">
                                Cancelar
                            </a>
                        }

                    </td>

                </tr>
            }
        }

    </tbody>

</table>