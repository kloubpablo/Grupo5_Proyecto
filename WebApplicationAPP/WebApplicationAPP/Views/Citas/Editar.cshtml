@model WebApplicationAPP.Models.Cita

@{
    ViewData["Title"] = "Editar Cita";
}

<h2 class="mb-4">
    ✏️ Editar Cita
</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger text-center">
        @ViewBag.Error
    </div>
}

<form method="post">

    <input type="hidden"
           asp-for="IdCita" />

    <input type="hidden"
           asp-for="IdCliente" />

    <input type="hidden"
           asp-for="Estado" />

    <div class="mb-3">

        <label class="form-label">
            Fecha
        </label>

        <input asp-for="Fecha"
               class="form-control"
               type="date" />

    </div>

    <div class="mb-3">

        <label class="form-label">
            Hora
        </label>

        <input asp-for="Hora"
               class="form-control"
               type="time" />

    </div>

    <div class="mb-3">

        <label class="form-label">
            Barbero
        </label>

        <select asp-for="Barbero"
                class="form-select">

            @foreach (var b in ViewBag.Barberos)
            {
                <option value="@b.Nombre">
                    @b.Nombre
                </option>
            }

        </select>

    </div>

    <div class="d-flex gap-2">

        <button class="btn btn-warning text-dark"
                type="submit">

            💾 Guardar Cambios

        </button>

        <a href="/Citas"
               class="btn btn-secondary">

            Cancelar

        </a>

    </div>

</form>