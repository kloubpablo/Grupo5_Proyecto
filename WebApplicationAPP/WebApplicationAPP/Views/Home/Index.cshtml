@{
    ViewData["Title"] = "Inicio";
}

<div class="row">
    <div class="col-12">

        <section class="box">

            <header class="text-center">
                <h2 class="major">
                    <span>💈 Bienvenido a Barbería App</span>
                </h2>
                <p style="color:#cbd5f5;">
                    Sistema de gestión profesional para barberías
                </p>
            </header>

            <p class="text-center">
                Administra de forma eficiente los módulos principales:
                <strong>Clientes</strong>, <strong>Citas</strong>,
                <strong>Turnos</strong> y <strong>Pagos</strong>.
            </p>

            <hr />

            <!-- 🔹 ACCESOS -->
            <div class="row text-center">

                <div class="col-md-3 mb-3">
                    <a asp-controller="Clientes" asp-action="Index" class="button primary w-100">
                        👤 Clientes
                    </a>
                </div>

                <div class="col-md-3 mb-3">
                    <a asp-controller="Citas" asp-action="Index" class="button alt w-100">
                        📅 Citas
                    </a>
                </div>

                <div class="col-md-3 mb-3">
                    <a asp-controller="Atencion" asp-action="Index" class="button alt w-100">
                        💈 Turnos
                    </a>
                </div>

                <div class="col-md-3 mb-3">
                    <a asp-controller="Pagos" asp-action="Index" class="button alt w-100">
                        💰 Pagos
                    </a>
                </div>

            </div>

            <hr />

            <!-- 🔹 MENSAJE FINAL -->
            <p class="text-center" style="color:#94a3b8;">
                Usa el menú superior para acceder a todas las funcionalidades del sistema.
            </p>

        </section>

    </div>
</div>