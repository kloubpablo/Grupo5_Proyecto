@{
    ViewData["Title"] = "Inicio";
}

<div class="row">
    <div class="col-12">

        <section class="box">

            <header>
                <h2 class="major">
                    <span>Bienvenido a Barbería App</span>
                </h2>
            </header>

            <p>
                Este sistema permite administrar las operaciones principales de la barbería,
                incluyendo gestión de <strong>Clientes</strong>, <strong>Citas</strong>,
                atención de <strong>Turnos</strong> y control de <strong>Pagos</strong>.
            </p>

            <p>
                Utiliza el menú superior para navegar entre los diferentes módulos del sistema.
            </p>

            <ul class="actions">
                <li>
                    <a asp-controller="Clientes" asp-action="Index" class="button primary">
                        Ver Clientes
                    </a>
                </li>

                <li>
                    <a asp-controller="Citas" asp-action="Index" class="button alt">
                        Ver Citas
                    </a>
                </li>

                <li>
                    <a asp-controller="Atencion" asp-action="Index" class="button alt">
                        Turnos
                    </a>
                </li>

                <li>
                    <a asp-controller="Pagos" asp-action="Index" class="button alt">
                        Pagos
                    </a>
                </li>
            </ul>

        </section>

    </div>
</div>